# ─────────────────────────────────────────────────────────────────────────────
# HabitCheck AI — Environment Configuration
#
# Copy this file to .env and fill in the values for your environment.
# .env is listed in .gitignore and must NEVER be committed to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Flask secret key used for session signing.
# Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET

# Flask environment ("development" | "production")
FLASK_ENV=development

# ─── Firebase ────────────────────────────────────────────────────────────────
# Path to your Firebase service-account private key JSON file.
# Download it from: Firebase Console → Project Settings → Service Accounts
FIREBASE_KEY_PATH=firebase_key.json

# Firebase Realtime Database URL (found in Firebase Console)
FIREBASE_DB_URL=https://your-project-id-default-rtdb.firebaseio.com/

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for cross-origin requests.
# Example (Lovable / local dev):
#   CORS_ORIGINS=https://your-app.lovable.app,http://localhost:3000
#
# Use * to allow all origins (not recommended for production).
CORS_ORIGINS=http://localhost:3000
